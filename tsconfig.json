{
  "compilerOptions": {
    "target": "ES2022",

    "module": "commonjs",

    "moduleResolution": "node",

    "lib": [
      "ES2022",
      "DOM"
    ],

    "types": [
      "node"
    ],

    "rootDir": "./src",

    "outDir": "./dist",

    "strict": false,

    "esModuleInterop": true,

    "allowSyntheticDefaultImports": true,

    "resolveJsonModule": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "sourceMap": true,

    "incremental": true
  },

  "include": [
    "src/**/*"
  ],

  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts"
  ]
}